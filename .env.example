# ===== DATABASE =====
# On Render, DATABASE_URL is auto-set from the managed PostgreSQL instance.
# Locally, set it directly:
DATABASE_URL=postgresql+asyncpg://gestronomy:gestronomy@localhost:5432/gestronomy
DATABASE_URL_SYNC=postgresql://gestronomy:gestronomy@localhost:5432/gestronomy

# ===== REDIS =====
REDIS_URL=redis://localhost:6379/0

# ===== AUTH =====
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== SECURITY =====
# Max accepted request payload size in bytes.
MAX_REQUEST_SIZE_BYTES=1048576
# Rate limits per client IP within a 60-second window.
AUTH_RATE_LIMIT_PER_MINUTE=12
PUBLIC_RATE_LIMIT_PER_MINUTE=60

# ===== AI / LLM =====
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ===== APP =====
APP_NAME=Gestronomy
APP_ENV=development
DEBUG=true
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:3000
# In non-development environments, users must have restaurant_id set.
# APP_ENV=production enforces strict tenant context.

# ===== CELERY =====
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== FRONTEND (Next.js) =====
# Set on Render to the backend URL, e.g. https://gestronomy-api.onrender.com
# NEXT_PUBLIC_API_URL=https://gestronomy-api.onrender.com
